# 复制为 .env 后填入你的 key，研究的工作目录下放一份就能用
# 也可以放到 ~/.research_agent.env 全局生效

# 必填：DeepSeek / 硅基流动 API key
# 申请：https://cloud.siliconflow.cn/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# 可选：Semantic Scholar API key（提速，避免 429）
# 申请：https://www.semanticscholar.org/product/api#api-key-form
# S2_API_KEY=

# 可选：HTTP 代理（国内访问 arXiv / S2 加速）
# HTTP_PROXY=http://127.0.0.1:7897

# 可选：批量精读并行 worker 数
# auto = 检测 GPU 自动并行 / disabled = 强制串行 / 整数 = 强制 N 个
# PARALLEL_WORKERS=auto
